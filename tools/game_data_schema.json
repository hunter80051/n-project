{
  "schemaVersion": 1,
  "versionFormat": "YYYYMMDD.N",
  "tables": {
    "balance": {
      "sheetName": "balance",
      "fileName": "balance.csv",
      "description": "全域模擬、生成與成長參數。",
      "identityFields": ["key"],
      "stableIds": true,
      "fields": [
        {"name": "key", "kind": "balanceKey", "required": true, "function": "參數的唯一名稱，程式以 data.balance[key] 讀取。", "rules": "不可空白或重複；使用英文字母開頭的英數 camelCase。", "implementation": "implemented"},
        {"name": "value", "kind": "dynamic", "required": true, "function": "參數值，依 type 轉為 number、boolean 或 string。", "rules": "必須符合 type；number 不可為 NaN。", "implementation": "implemented"},
        {"name": "type", "kind": "enum", "enum": ["number", "boolean", "string"], "required": true, "function": "控制 value 的載入型別。", "rules": "只可填 number、boolean、string。", "implementation": "implemented"},
        {"name": "description", "kind": "string", "required": true, "function": "供配置維護者閱讀的參數說明。", "rules": "請清楚描述單位與影響範圍。", "implementation": "not_implemented", "note": "不會被遊戲執行期讀取。"}
      ],
      "currentKeys": [
        {"key": "tileSize", "implementation": "not_implemented", "note": "目前渲染尺寸仍寫在 JavaScript。"},
        {"key": "canvasWidth", "implementation": "not_implemented", "note": "Canvas width 目前寫在 index.html。"},
        {"key": "canvasHeight", "implementation": "not_implemented", "note": "Canvas height 目前寫在 index.html。"},
        {"key": "simulationStepMs", "implementation": "implemented"},
        {"key": "partyMoveSpeed", "implementation": "implemented"},
        {"key": "roomCountMin", "implementation": "implemented"},
        {"key": "roomCountMax", "implementation": "implemented"},
        {"key": "roomMinSize", "implementation": "implemented"},
        {"key": "roomMaxSize", "implementation": "implemented"},
        {"key": "roomMinArea", "implementation": "implemented"},
        {"key": "floorEnemyBase", "implementation": "not_implemented", "note": "敵人數目前由 dungeons.csv 的樓層欄位決定。"},
        {"key": "xpBase", "implementation": "implemented"},
        {"key": "xpGrowth", "implementation": "implemented"},
        {"key": "spRegenPerSecond", "implementation": "implemented"},
        {"key": "equipmentNoticeMs", "implementation": "implemented"},
        {"key": "dungeonDifficultyGrowth", "implementation": "implemented"}
      ]
    },
    "characters": {
      "sheetName": "characters",
      "fileName": "characters.csv",
      "description": "固定小隊角色、戰鬥定位、外觀索引與基礎能力。",
      "identityFields": ["characterId"],
      "stableIds": true,
      "exactRows": 4,
      "fields": [
        {"name": "characterId", "kind": "id", "required": true, "function": "角色唯一 ID，供技能選擇、UI 與執行期狀態引用。", "rules": "不可空白或重複；格式為小寫英數及底線。", "implementation": "implemented"},
        {"name": "name", "kind": "string", "required": true, "function": "角色顯示名稱。", "rules": "不可空白。", "implementation": "implemented"},
        {"name": "role", "kind": "string", "required": true, "function": "角色職責顯示；Healer 會優先成為治療卷軸施法者。", "rules": "目前建議 Tank、Healer、Caster、Striker。", "implementation": "partial", "note": "只有 Healer 具有額外程式行為，其餘主要供顯示。"},
        {"name": "combatStyle", "kind": "enum", "enum": ["melee", "ranged"], "required": true, "function": "控制近戰／遠程站位與投射物行為。", "rules": "只可填 melee 或 ranged。", "implementation": "implemented"},
        {"name": "attackType", "kind": "enum", "enum": ["physical", "magic"], "required": true, "function": "控制遠程投射物與攻擊視覺類型。", "rules": "只可填 physical 或 magic。", "implementation": "implemented"},
        {"name": "color", "kind": "color", "required": true, "function": "角色 UI 與 Canvas 主色。", "rules": "使用 #RRGGBB。", "implementation": "implemented"},
        {"name": "spriteId", "kind": "id", "required": true, "function": "選擇角色程式繪圖外觀。", "rules": "目前使用 sprite_dinu、sprite_hoya、sprite_lynn、sprite_bob。", "implementation": "partial", "note": "新 spriteId 不會自動產生專屬造型。"},
        {"name": "maxHp", "kind": "number", "min": 1, "required": true, "function": "角色初始最大生命值。", "rules": "大於 0。", "implementation": "implemented"},
        {"name": "maxSp", "kind": "number", "min": 0, "required": true, "function": "角色初始最大 SP。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "attack", "kind": "number", "min": 0, "required": true, "function": "角色基礎攻擊力。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "defense", "kind": "number", "min": 0, "required": true, "function": "角色基礎防禦力。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "speed", "kind": "number", "min": 0.01, "required": true, "function": "角色每秒移動格數。", "rules": "必須大於 0。", "implementation": "implemented"},
        {"name": "attackRange", "kind": "number", "min": 0.1, "required": true, "function": "角色可攻擊距離，單位為地圖格。", "rules": "必須大於 0；遠程通常大於近戰。", "implementation": "implemented"},
        {"name": "attackCooldownMs", "kind": "number", "min": 1, "required": true, "function": "普通攻擊冷卻毫秒數。", "rules": "必須大於 0。", "implementation": "implemented"},
        {"name": "basicSkillId", "kind": "id", "required": true, "function": "角色基本技能 ID。", "rules": "必須存在於 skills.skillId。", "implementation": "implemented"},
        {"name": "skillPoolId", "kind": "id", "required": true, "function": "升級時抽選技能的技能池 ID。", "rules": "skills 中至少要有一列使用相同 skillPoolId。", "implementation": "implemented"}
      ]
    },
    "skills": {
      "sheetName": "skills",
      "fileName": "skills.csv",
      "description": "角色基本技能與升級被動技能。",
      "identityFields": ["skillId"],
      "stableIds": true,
      "fields": [
        {"name": "skillId", "kind": "id", "required": true, "function": "技能唯一 ID。", "rules": "不可空白或重複；格式為小寫英數及底線。", "implementation": "implemented"},
        {"name": "skillPoolId", "kind": "id", "required": true, "function": "技能所屬升級池。", "rules": "須與角色 skillPoolId 對應。", "implementation": "implemented"},
        {"name": "name", "kind": "string", "required": true, "function": "技能顯示名稱。", "rules": "不可空白。", "implementation": "implemented"},
        {"name": "description", "kind": "string", "required": true, "function": "技能選擇介面的說明文字。", "rules": "請與實際效果一致。", "implementation": "implemented"},
        {"name": "effectType", "kind": "enum", "enum": ["guardStrike", "damage", "heal", "maxHp", "maxSp", "attackBuff", "defenseBuff", "haste", "healPower", "regen", "spRegen", "aoeBonus", "chainBonus", "hybridBuff"], "required": true, "function": "指定基本攻擊、治療或被動能力的程式效果。", "rules": "只可使用目前列出的類型；新增類型需修改 JavaScript。", "implementation": "partial", "note": "guardStrike 目前只使用傷害倍率，說明中的暫時防禦尚未實作。"},
        {"name": "targetType", "kind": "enum", "enum": ["enemy", "ally", "self", "party"], "required": true, "function": "區分個人與全隊被動，並描述基本技能目標。", "rules": "只可填 enemy、ally、self、party。", "implementation": "implemented"},
        {"name": "power", "kind": "number", "min": 0, "required": true, "function": "傷害／治療倍率或被動加成值。", "rules": "不得小於 0；百分比以小數表示。", "implementation": "implemented"},
        {"name": "spCost", "kind": "number", "min": 0, "required": true, "function": "基本技能消耗 SP。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "cooldownMs", "kind": "number", "min": 0, "required": true, "function": "技能冷卻毫秒數。", "rules": "不得小於 0。", "implementation": "partial", "note": "治療基本技能會使用；一般攻擊通常由角色 attackCooldownMs 決定。"},
        {"name": "requiredLevel", "kind": "integer", "min": 1, "required": true, "function": "升級選項可出現的最低角色等級。", "rules": "大於等於 1 的整數。", "implementation": "implemented"},
        {"name": "iconId", "kind": "id", "required": true, "function": "預留技能圖示索引。", "rules": "使用小寫英數及底線。", "implementation": "not_implemented", "note": "目前技能 UI 不讀取 iconId。"}
      ]
    },
    "enemies": {
      "sheetName": "enemies",
      "fileName": "enemies.csv",
      "description": "一般敵人與 Boss 的基礎能力及掉落表。",
      "identityFields": ["enemyId"],
      "stableIds": true,
      "fields": [
        {"name": "enemyId", "kind": "id", "required": true, "function": "敵人唯一 ID。", "rules": "不可空白或重複；格式為小寫英數及底線。", "implementation": "implemented"},
        {"name": "name", "kind": "string", "required": true, "function": "敵人與事件顯示名稱。", "rules": "不可空白。", "implementation": "implemented"},
        {"name": "tier", "kind": "integer", "min": 1, "required": true, "function": "預留敵人階級。", "rules": "大於等於 1 的整數。", "implementation": "not_implemented", "note": "目前不影響生成或戰鬥。"},
        {"name": "color", "kind": "color", "required": true, "function": "敵人 Canvas 主色。", "rules": "使用 #RRGGBB。", "implementation": "implemented"},
        {"name": "spriteId", "kind": "id", "required": true, "function": "預留敵人外觀索引。", "rules": "使用小寫英數及底線。", "implementation": "not_implemented", "note": "目前敵人以共用程式圖形及 color 繪製。"},
        {"name": "maxHp", "kind": "number", "min": 1, "required": true, "function": "敵人基礎最大生命值。", "rules": "大於 0。", "implementation": "implemented"},
        {"name": "attack", "kind": "number", "min": 0, "required": true, "function": "敵人基礎攻擊力。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "defense", "kind": "number", "min": 0, "required": true, "function": "敵人基礎防禦力。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "speed", "kind": "number", "min": 0.01, "required": true, "function": "敵人每秒移動格數。", "rules": "必須大於 0。", "implementation": "implemented"},
        {"name": "attackRange", "kind": "number", "min": 0.1, "required": true, "function": "敵人攻擊距離。", "rules": "必須大於 0。", "implementation": "implemented"},
        {"name": "attackCooldownMs", "kind": "number", "min": 1, "required": true, "function": "敵人攻擊冷卻毫秒數。", "rules": "必須大於 0。", "implementation": "implemented"},
        {"name": "xp", "kind": "number", "min": 0, "required": true, "function": "擊敗後每名角色取得的經驗值。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "lootTableId", "kind": "id", "required": true, "function": "敵人死亡後使用的掉落表。", "rules": "必須存在於 loot_tables.lootTableId。", "implementation": "implemented"},
        {"name": "isBoss", "kind": "boolean", "required": true, "function": "控制 Boss 驗證、尺寸與 Boss 血條。", "rules": "只可填 true 或 false。", "implementation": "implemented"}
      ]
    },
    "items": {
      "sheetName": "items",
      "fileName": "items.csv",
      "description": "武器與防具的顯示資料、能力加成及換裝評分。",
      "identityFields": ["itemId"],
      "stableIds": true,
      "fields": [
        {"name": "itemId", "kind": "id", "required": true, "function": "裝備唯一 ID。", "rules": "不可空白或重複；格式為小寫英數及底線。", "implementation": "implemented"},
        {"name": "name", "kind": "string", "required": true, "function": "裝備顯示名稱。", "rules": "不可空白。", "implementation": "implemented"},
        {"name": "slot", "kind": "enum", "enum": ["weapon", "armor"], "required": true, "function": "決定武器或防具欄位。", "rules": "只可填 weapon 或 armor。", "implementation": "implemented"},
        {"name": "rarity", "kind": "enum", "enum": ["common", "uncommon", "rare"], "required": true, "function": "預留裝備稀有度。", "rules": "目前建議 common、uncommon、rare。", "implementation": "not_implemented", "note": "目前不影響掉落、UI 或能力。"},
        {"name": "iconId", "kind": "id", "required": true, "function": "預留裝備圖示索引。", "rules": "使用小寫英數及底線。", "implementation": "not_implemented", "note": "目前 UI 不讀取 iconId。"},
        {"name": "attackBonus", "kind": "number", "min": 0, "required": true, "function": "裝備增加的攻擊力。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "defenseBonus", "kind": "number", "min": 0, "required": true, "function": "裝備增加的防禦力。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "maxHpBonus", "kind": "number", "min": 0, "required": true, "function": "裝備增加的最大 HP。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "maxSpBonus", "kind": "number", "min": 0, "required": true, "function": "裝備增加的最大 SP。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "score", "kind": "number", "min": 0, "required": true, "function": "換裝提案的比較評分。", "rules": "不得小於 0；應與能力加成強度一致。", "implementation": "implemented"}
      ]
    },
    "lootTables": {
      "sheetName": "loot_tables",
      "fileName": "loot_tables.csv",
      "description": "敵人掉落候選；每一列目前獨立依 chance 投擲。",
      "identityFields": ["lootTableId", "dropType", "dropId"],
      "stableIds": false,
      "fields": [
        {"name": "lootTableId", "kind": "id", "required": true, "function": "將多個掉落候選分到同一掉落表。", "rules": "至少須被一名敵人的 lootTableId 引用。", "implementation": "implemented"},
        {"name": "dropType", "kind": "enum", "enum": ["item", "scroll"], "required": true, "function": "指定掉落內容為裝備或卷軸。", "rules": "只可填 item 或 scroll。", "implementation": "implemented"},
        {"name": "dropId", "kind": "id", "required": true, "function": "掉落物 ID。", "rules": "依 dropType 指向 items.itemId 或 scrolls.scrollId。", "implementation": "implemented"},
        {"name": "weight", "kind": "number", "min": 0, "required": true, "function": "預留權重抽選值。", "rules": "不得小於 0。", "implementation": "not_implemented", "note": "目前不做權重抽選。"},
        {"name": "chance", "kind": "number", "min": 0, "max": 1, "required": true, "function": "該列獨立掉落機率。", "rules": "0 到 1；0.25 代表 25%。", "implementation": "implemented"},
        {"name": "minQuantity", "kind": "integer", "min": 1, "required": true, "function": "成功掉落時的最小數量。", "rules": "大於等於 1，且不可大於 maxQuantity。", "implementation": "implemented"},
        {"name": "maxQuantity", "kind": "integer", "min": 1, "required": true, "function": "成功掉落時的最大數量。", "rules": "大於等於 minQuantity。", "implementation": "implemented"}
      ]
    },
    "scrolls": {
      "sheetName": "scrolls",
      "fileName": "scrolls.csv",
      "description": "玩家可主動施放及由敵人掉落的卷軸。",
      "identityFields": ["scrollId"],
      "stableIds": true,
      "fields": [
        {"name": "scrollId", "kind": "id", "required": true, "function": "卷軸唯一 ID。", "rules": "不可空白或重複；格式為小寫英數及底線。", "implementation": "implemented"},
        {"name": "name", "kind": "string", "required": true, "function": "卷軸按鈕與事件顯示名稱。", "rules": "不可空白。", "implementation": "implemented"},
        {"name": "description", "kind": "string", "required": true, "function": "卷軸按鈕說明文字。", "rules": "請與實際效果一致。", "implementation": "implemented"},
        {"name": "effectType", "kind": "enum", "enum": ["aoeDamage", "chainDamage", "partyHeal"], "required": true, "function": "決定範圍傷害、連鎖傷害或全隊治療。", "rules": "只可使用目前三種；新增類型需修改 JavaScript。", "implementation": "implemented"},
        {"name": "targetType", "kind": "enum", "enum": ["enemy", "party"], "required": true, "function": "描述卷軸目標類型。", "rules": "傷害填 enemy，治療填 party。", "implementation": "not_implemented", "note": "目前程式只依 effectType 判斷目標。"},
        {"name": "power", "kind": "number", "min": 0, "required": true, "function": "傷害或治療的固定數值。", "rules": "不得小於 0。", "implementation": "implemented"},
        {"name": "spCost", "kind": "number", "min": 0, "required": true, "function": "預留卷軸 SP 成本。", "rules": "不得小於 0。", "implementation": "not_implemented", "note": "目前施放卷軸不消耗 SP。"},
        {"name": "iconId", "kind": "id", "required": true, "function": "預留卷軸圖示索引。", "rules": "使用小寫英數及底線。", "implementation": "not_implemented", "note": "目前按鈕圖示依 effectType 顯示符號。"},
        {"name": "initialQuantity", "kind": "integer", "min": 0, "required": true, "function": "新遊戲開始時持有數量。", "rules": "大於等於 0 的整數。", "implementation": "implemented"}
      ]
    },
    "dungeons": {
      "sheetName": "dungeons",
      "fileName": "dungeons.csv",
      "description": "地下城輪替順序、主題、敵人池、樓層數量與 Boss。",
      "identityFields": ["dungeonId"],
      "stableIds": true,
      "fields": [
        {"name": "dungeonId", "kind": "id", "required": true, "function": "地下城唯一 ID。", "rules": "不可空白或重複；格式為小寫英數及底線。", "implementation": "implemented"},
        {"name": "name", "kind": "string", "required": true, "function": "大地圖與地下城標題顯示名稱。", "rules": "不可空白。", "implementation": "implemented"},
        {"name": "themeColor", "kind": "color", "required": true, "function": "入口與地下城渲染主題色。", "rules": "使用 #RRGGBB。", "implementation": "implemented"},
        {"name": "enemyPool", "kind": "idList", "required": true, "function": "第 1、2 層可隨機生成的敵人 ID 清單。", "rules": "以 | 分隔；每個 ID 必須存在於 enemies，且清單不可空白。", "implementation": "implemented"},
        {"name": "floor1EnemyCount", "kind": "integer", "min": 1, "required": true, "function": "第 1 層生成敵人數。", "rules": "大於等於 1 的整數。", "implementation": "implemented"},
        {"name": "floor2EnemyCount", "kind": "integer", "min": 1, "required": true, "function": "第 2 層生成敵人數。", "rules": "大於等於 1 的整數。", "implementation": "implemented"},
        {"name": "bossEnemyId", "kind": "id", "required": true, "function": "第 3 層 Boss ID。", "rules": "必須存在於 enemies，且 isBoss=true。", "implementation": "implemented"},
        {"name": "difficultyScale", "kind": "number", "min": 0.01, "required": true, "function": "該地下城敵人 HP、攻擊與防禦倍率。", "rules": "必須大於 0。", "implementation": "implemented"}
      ]
    }
  }
}
